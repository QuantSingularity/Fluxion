# Fluxion Frontend Environment Variables
# Copy this file to .env and fill in your values

# Smart Contract Addresses (Ethereum Mainnet)
VITE_POOL_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
VITE_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000

# RPC Endpoints (optional - uses MetaMask if not set)
VITE_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY
VITE_CHAIN_ID=1

# API Backend (optional)
VITE_API_BASE_URL=http://localhost:8000
